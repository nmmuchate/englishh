# Firebase Web App Configuration
# Copy this file to .env.local and fill in your values from:
# Firebase Console -> Project Settings -> General -> Your apps -> Web app -> SDK config
#
# IMPORTANT: .env.local is git-ignored and must never be committed.
# This .env.example file IS committed — it contains no real secrets.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
